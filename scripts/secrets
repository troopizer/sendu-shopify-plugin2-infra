#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

DEFAULT_SECRET_FALLBACK="sendu/staging/app-shared"
DEFAULT_AWS_PROFILE="sendu"
DEFAULT_SECRET_ID="${APP_SECRET_ID:-}"
AWS_PROFILE_NAME="${DEFAULT_AWS_PROFILE}"
PARSED_ARGS=()

if [[ -z "${DEFAULT_SECRET_ID}" ]] && [[ -f "${REPO_ROOT}/parameters.staging.json" ]]; then
  DEFAULT_SECRET_ID="$({
    jq -r '.[] | select(.ParameterKey == "AppSecretsSecretId") | .ParameterValue' "${REPO_ROOT}/parameters.staging.json" 2>/dev/null || true
  } | head -n 1)"
fi

SECRET_ID="${DEFAULT_SECRET_ID:-${DEFAULT_SECRET_FALLBACK}}"

REQUIRED_KEYS=(
  "UPSTREAM_API_TOKEN"
  "SHOPIFY_API_KEY"
  "SHOPIFY_API_SECRET"
  "RAILS_MASTER_KEY"
  "DB_PASSWORD"
  "DB_USERNAME"
  "SHOPIFY_APP_HOST"
  "SHOPIFY_FRONTEND_URL"
)

usage() {
  cat <<'EOF'
Usage:
  secrets [--profile <name>] edit              (opens full secret JSON in $EDITOR)
  secrets [--profile <name>] get [KEY]
  secrets [--profile <name>] init              (creates default secret if missing)
  secrets [--profile <name>] ls
  secrets [--profile <name>] set <KEY>         (reads value from stdin or prompts securely)

Examples:
  printf '%s' 'value' | secrets set DB_USERNAME
  secrets set DB_USERNAME

Environment:
  APP_SECRET_ID             Override default secret id/name
  EDITOR                    Editor used by 'secrets edit' (default: vi)

Options:
  --profile <name>          AWS CLI profile to use (default: sendu)
EOF
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

parse_global_args() {
  PARSED_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile)
        [[ $# -ge 2 ]] || die "Missing value for --profile"
        [[ -n "$2" ]] || die "Missing value for --profile"
        AWS_PROFILE_NAME="$2"
        shift 2
        ;;
      --)
        shift
        PARSED_ARGS+=("$@")
        break
        ;;
      --*)
        die "Unknown global option: $1"
        ;;
      *)
        PARSED_ARGS+=("$@")
        break
        ;;
    esac
  done
}

aws_cli() {
  aws --profile "${AWS_PROFILE_NAME}" "$@"
}

secret_exists() {
  aws_cli secretsmanager describe-secret --secret-id "${SECRET_ID}" >/dev/null 2>&1
}

get_secret_string() {
  aws_cli secretsmanager get-secret-value \
    --secret-id "${SECRET_ID}" \
    --query SecretString \
    --output text
}

validate_json_object() {
  jq -e 'type == "object"' >/dev/null
}

cmd_ls() {
  secret_exists || die "Secret '${SECRET_ID}' does not exist. Run: secrets init"
  get_secret_string | jq -r 'keys[]'
}

cmd_get() {
  local key="${1:-}"
  secret_exists || die "Secret '${SECRET_ID}' does not exist. Run: secrets init"

  if [[ -z "${key}" ]]; then
    get_secret_string | jq .
    return
  fi

  local value
  value="$(get_secret_string | jq -r --arg key "${key}" 'if has($key) then .[$key] else empty end')"
  [[ -n "${value}" ]] || die "Key '${key}' not found in secret '${SECRET_ID}'"
  printf '%s\n' "${value}"
}

cmd_set() {
  local key="${1:-}"
  [[ -n "${key}" ]] || die "Usage: secrets set <KEY>"
  secret_exists || die "Secret '${SECRET_ID}' does not exist. Run: secrets init"

  local value
  if [[ -t 0 ]]; then
    [[ -r /dev/tty ]] || die "Interactive input is unavailable. Provide the value via stdin."

    if ! IFS= read -r -s -p "Enter value for ${key}: " value </dev/tty; then
      printf '\n' >/dev/tty
      die "Failed to read value for '${key}'"
    fi

    printf '\n' >/dev/tty
  else
    value="$(cat)"
  fi

  local current updated
  current="$(get_secret_string)"
  printf '%s' "${current}" | validate_json_object || die "SecretString is not a JSON object"

  updated="$(printf '%s' "${current}" | jq --arg key "${key}" --arg value "${value}" '.[$key] = $value')"

  aws_cli secretsmanager put-secret-value \
    --secret-id "${SECRET_ID}" \
    --secret-string "${updated}" >/dev/null

  printf "Updated key '%s' in secret '%s'.\n" "${key}" "${SECRET_ID}"
}

cmd_edit() {
  secret_exists || die "Secret '${SECRET_ID}' does not exist. Run: secrets init"
  local editor="${EDITOR:-vi}"
  local tmp
  tmp="$(mktemp)"
  trap 'rm -f "${tmp}"' EXIT

  get_secret_string | jq . >"${tmp}"
  "${editor}" "${tmp}"

  jq -e . "${tmp}" >/dev/null || die "Edited file is not valid JSON"
  jq -e 'type == "object"' "${tmp}" >/dev/null || die "Edited JSON must be an object"

  aws_cli secretsmanager put-secret-value \
    --secret-id "${SECRET_ID}" \
    --secret-string "$(cat "${tmp}")" >/dev/null

  printf "Updated secret '%s' from editor.\n" "${SECRET_ID}"
}

cmd_init() {
  if secret_exists; then
    printf "Secret '%s' already exists.\n" "${SECRET_ID}"
    return
  fi

  local initial
  initial='{}'
  for k in "${REQUIRED_KEYS[@]}"; do
    initial="$(printf '%s' "${initial}" | jq --arg key "${k}" '.[$key] = ""')"
  done

  aws_cli secretsmanager create-secret \
    --name "${SECRET_ID}" \
    --secret-string "${initial}" >/dev/null

  printf "Created secret '%s' with default keys.\n" "${SECRET_ID}"
}

main() {
  parse_global_args "$@"
  set -- "${PARSED_ARGS[@]}"

  local cmd="${1:-}"
  case "${cmd}" in
    -h|--help|help|"")
      usage
      ;;
    ls)
      require_cmd aws
      require_cmd jq
      shift
      cmd_ls "$@"
      ;;
    get)
      require_cmd aws
      require_cmd jq
      shift
      cmd_get "$@"
      ;;
    set)
      require_cmd aws
      require_cmd jq
      shift
      cmd_set "$@"
      ;;
    edit)
      require_cmd aws
      require_cmd jq
      shift
      cmd_edit "$@"
      ;;
    init)
      require_cmd aws
      require_cmd jq
      shift
      cmd_init "$@"
      ;;
    *)
      usage
      die "Unknown command: ${cmd}"
      ;;
  esac
}

main "$@"
